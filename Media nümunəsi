<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media Nümunəsi6</title>
</head>
<body>
    <h1>Media elementləri nümunəsi</h1>

    <h3>Audio elementi</h3>
<audio controls>
<source src="audio.mp3" type="audio/mpeg" />
<source src="audio.ogg" type="audio/ogg" />
</audio>

<h3>Video elementi</h3>
<video controls>
<source src="video.mp4" type="video/mp4" />
<source src="video.webm" type="video/webm" />
</video>

<h3>Şəkil elementi</h3>
<picture>
<source src="sekil.webp" type="image/webp" />
<source src="sekil.jpg" type="image/jpg" />
<img src="sekil.jpg">
</picture>

</body>
</html>
